---
import { Icon } from 'astro-icon/components';

import TableOfContents from '~/components/blog/TableOfContents.astro';
import type { Heading } from '~/types';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { SITE } from 'astrowind:config';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
  headings?: Heading[];
}

const { post, url, headings = [] } = Astro.props;
const authorName = post.author || SITE.name;
---

<section class="py-8 sm:py-16 lg:py-20">
  <article class="mx-auto max-w-5xl px-4 sm:px-6">
    <nav class="mb-4 text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb">
      <a
        href={getPermalink('/', 'home')}
        class="transition-colors hover:text-slate-700 hover:underline dark:hover:text-slate-200"
      >
        Home
      </a>
      {
        post.category && (
          <>
            <span class="mx-2 text-slate-400 dark:text-slate-500">/</span>
            <a
              href={getPermalink(post.category.slug, 'category')}
              class="transition-colors hover:text-slate-700 hover:underline dark:hover:text-slate-200"
            >
              {post.category.title}
            </a>
          </>
        )
      }
      <span class="mx-2 text-slate-400 dark:text-slate-500">/</span>
      <span aria-current="page" class="truncate text-slate-600 dark:text-slate-300">
        {post.title}
      </span>
    </nav>

    <header class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <h1 class="text-4xl font-bold leading-tighter tracking-tighter font-heading md:text-5xl">
        {post.title}
      </h1>

      <p class="my-6 text-base text-slate-600 dark:text-slate-400 md:text-lg">
        {post.excerpt}
      </p>

      <div class="my-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
        <div class="flex items-center gap-1.5">
          <Icon name="tabler:clock" class="h-4 w-4" />
          <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
        </div>

        {
          authorName && (
            <div class="flex items-center gap-1.5">
              <span class="text-slate-300 dark:text-slate-600">·</span>
              <Icon name="tabler:user" class="h-4 w-4" />
              <span>{authorName}</span>
            </div>
          )
        }

        {
          post.category && (
            <div class="flex items-center gap-1.5">
              <span class="text-slate-300 dark:text-slate-600">·</span>
              <a
                class="transition-colors hover:text-slate-700 hover:underline dark:hover:text-slate-200"
                href={getPermalink(post.category.slug, 'category')}
              >
                {post.category.title}
              </a>
            </div>
          )
        }

        {
          post.readingTime && (
            <div class="flex items-center gap-1.5">
              <span class="text-slate-300 dark:text-slate-600">·</span>
              <span>{post.readingTime} min read</span>
            </div>
          )
        }
      </div>

      {
        post.image ? (
          <div class="mt-8">
            <Image
              src={post.image}
              class="w-full max-w-full mx-auto mb-6 sm:rounded-md bg-gray-400 dark:bg-slate-700"
              widths={[400, 900, 1200, 1600]}
              sizes="(max-width: 768px) 100vw, (max-width: 1280px) 90vw, 1200px"
              alt={post?.excerpt || ''}
              width={1600}
              height={900}
              loading="eager"
              decoding="async"
            />
          </div>
        ) : (
          <div class="mt-8">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>

    <div class="mt-8 xl:grid xl:grid-cols-[minmax(0,1fr)_14rem] xl:gap-12">
      <div class="min-w-0">
        <div
          class="prose prose-base lg:prose-base max-w-none font-normal dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tight prose-headings:tracking-tight prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg prose-headings:scroll-mt-24 prose-li:my-0"
        >
          <slot />
        </div>
      </div>

      <aside class="hidden xl:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} title="文章目录" />
        </div>
      </aside>
    </div>

    <div class="mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
  </article>
</section>
